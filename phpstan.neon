parameters:
    level: 1
    # application/views e application/migrations ficam de fora: ambos dependem
    # fortemente de propriedades magicas do CI3 (extract() nas views,
    # $this->db no CI_Migration) sem sinal real de bug a ganhar em troca.
    paths:
        - application/controllers
        - application/core
        - application/helpers
        - application/models
        - tests
    excludePaths:
        - application/cache/*
        - application/logs/*
    scanFiles:
        - system/core/Common.php
        - system/core/Controller.php
        - system/core/Model.php
        - system/libraries/Migration.php
        - system/core/Loader.php
        - system/core/Input.php
        - system/core/Output.php
        - system/core/Security.php
        - system/database/DB.php
        - system/database/DB_driver.php
        - system/database/DB_query_builder.php
        - system/database/DB_result.php
        - system/database/drivers/mysqli/mysqli_driver.php
        - system/libraries/Session/Session.php
        - system/libraries/Pagination.php
        - system/libraries/Form_validation.php
        - system/helpers/url_helper.php
        - system/helpers/form_helper.php
        - system/helpers/security_helper.php
