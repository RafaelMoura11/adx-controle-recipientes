{
    "name": "adx/controle-recipientes",
    "description": "Sistema de controle de entrada e saida de recipientes termicos - Desafio PHP ADX",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "endroid/qr-code": "^5.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/phpstan": "^2.2",
        "phpunit/phpunit": "^10.5"
    },
    "scripts": {
        "test": "phpunit",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "phpstan": "phpstan analyse",
        "check": [
            "@cs-check",
            "@phpstan",
            "@test"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "platform": {
            "php": "8.1.34"
        }
    }
}
